{
  "name": "liveclip",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "next dev apps/web",
    "dev:api": "tsx apps/api/src/server.ts",
    "dev:worker": "tsx apps/worker/src/index.ts",
    "postinstall": "node scripts/install-ytdlp-standalone.mjs",
    "build": "npm run typecheck && npm run build:web",
    "build:web": "next build apps/web",
    "start": "npm run start:web",
    "start:web": "next start apps/web",
    "start:api": "tsx apps/api/src/server.ts",
    "start:worker": "tsx apps/worker/src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint -c configs/eslint/eslint.config.mjs apps packages configs ecosystem.config.cjs tailwind.config.ts",
    "db:generate": "drizzle-kit generate --config configs/drizzle/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config configs/drizzle/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config configs/drizzle/drizzle.config.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.23.6",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "lucide-react": "^0.468.0",
    "next": "15.5.20",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.76",
    "yt-dlp-exec": "^1.0.2",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.17.0",
    "autoprefixer": "^10.4.21",
    "eslint-config-next": "15.5.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.7.2"
  }
}
